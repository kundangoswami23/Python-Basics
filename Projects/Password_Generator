import random
import string


class PasswordGenerator:

    def __init__(self):
        self.history = []

    def generate_password(self):

        print("\n========== PASSWORD GENERATOR ==========")

        try:
            length = int(input("Enter Password Length (8-50): "))

            if length < 8 or length > 50:
                print("Password length must be between 8 and 50.")
                return

        except ValueError:
            print("Please enter a valid number.")
            return

        print("\nSelect Password Type")
        print("1. Letters Only")
        print("2. Letters + Numbers")
        print("3. Letters + Numbers + Symbols (Strong)")
        print("4. Custom Password")

        choice = input("Enter Choice: ")

        if choice == "1":
            characters = string.ascii_letters

        elif choice == "2":
            characters = string.ascii_letters + string.digits

        elif choice == "3":
            characters = (
                string.ascii_letters +
                string.digits +
                string.punctuation
            )

        elif choice == "4":

            use_upper = input("Include Uppercase? (y/n): ").lower() == "y"
            use_lower = input("Include Lowercase? (y/n): ").lower() == "y"
            use_digits = input("Include Numbers? (y/n): ").lower() == "y"
            use_symbols = input("Include Symbols? (y/n): ").lower() == "y"

            characters = ""

            if use_upper:
                characters += string.ascii_uppercase

            if use_lower:
                characters += string.ascii_lowercase

            if use_digits:
                characters += string.digits

            if use_symbols:
                characters += string.punctuation

            if not characters:
                print("You must select at least one option.")
                return

        else:
            print("Invalid Choice.")
            return

        password = "".join(random.choice(characters) for _ in range(length))

        strength = self.check_strength(password)

        print("\n========== GENERATED PASSWORD ==========")
        print(password)
        print(f"\nStrength : {strength}")

        self.history.append(password)

    def check_strength(self, password):

        score = 0

        if any(c.islower() for c in password):
            score += 1

        if any(c.isupper() for c in password):
            score += 1

        if any(c.isdigit() for c in password):
            score += 1

        if any(c in string.punctuation for c in password):
            score += 1

        if len(password) >= 12:
            score += 1

        if score <= 2:
            return "Weak"

        elif score <= 4:
            return "Medium"

        else:
            return "Strong"

    def password_history(self):

        print("\n========== PASSWORD HISTORY ==========")

        if not self.history:
            print("No passwords generated.")
            return

        for i, password in enumerate(self.history, start=1):
            print(f"{i}. {password}")

    def clear_history(self):

        self.history.clear()
        print("History Cleared Successfully.")

    def menu(self):

        while True:

            print("\n" + "=" * 50)
            print("      PROFESSIONAL PASSWORD GENERATOR")
            print("=" * 50)
            print("1. Generate Password")
            print("2. View Password History")
            print("3. Clear History")
            print("4. Exit")
            print("=" * 50)

            choice = input("Enter Your Choice: ")

            if choice == "1":
                self.generate_password()

            elif choice == "2":
                self.password_history()

            elif choice == "3":
                self.clear_history()

            elif choice == "4":
                print("\nThank You For Using Password Generator.")
                break

            else:
                print("Invalid Choice! Please Try Again.")


if __name__ == "__main__":
    app = PasswordGenerator()
    app.menu()
